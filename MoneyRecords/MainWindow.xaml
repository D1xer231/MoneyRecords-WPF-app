<Window x:Class="MoneyRecords.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MoneyRecords" xmlns:viewmodels="clr-namespace:MoneyRecords.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        WindowStyle="None"
        Title="Money Records" Height="700" Width="1200" MinHeight="600" MinWidth="900">
    <Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown">

        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF001121"/>
                <GradientStop Color="Black" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Columns -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Left navigation bar -->
        <Grid Grid.Column="0" Grid.RowSpan="5">
            <Rectangle Fill="White" RadiusX="20" RadiusY="20" Opacity="0.3" Margin="10,20,10,10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            
            <StackPanel Margin="10">
                <!-- profile pic -->
                <Border Width="80" Height="80" Background="White" CornerRadius="15" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50,0,10">
                    <TextBlock  x:Name="UserImage_TextBlock" Text="A" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="User Name from db" Foreground="White" FontSize="20" Margin="10,10,0,30" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto" x:Name="UserNameTextBlock" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                
                <!-- home -->
                <Button Background="Gray" BorderThickness="0" Height="40" Margin="10,5,10,15" Click="ToHomeGrid_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/home.png" Width="20" Height="20"  Margin="10,0,10,0"/>
                        <TextBlock Text="Home" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- users -->
                <Button Background="Gray" BorderThickness="0" Height="40" Margin="10,5,10,15" Click="ToUsersGrid_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/user.png" Width="20" Height="20" Margin="10,0,10,0"/>
                        <TextBlock Text="Users" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- analytics -->
                <Button Background="Gray" BorderThickness="0" Height="40" Margin="10,5,10,15">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/chart-histogram.png" Width="20" Height="20" Margin="10,0,10,0"/>
                        <TextBlock Text="Analytics" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- reports -->
                <Button Background="Gray" BorderThickness="0" Height="40" Margin="10,5,10,15">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/newspaper.png" Width="20" Height="20" Margin="10,0,10,0"/>
                        <TextBlock Text="Reports" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- settings -->
                <Button Background="Gray" BorderThickness="0" Height="40" Margin="10,5,10,15">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/settings.png" Width="20" Height="20" Margin="10,0,10,0"/>
                        <TextBlock Text="Settings" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Top middle bar -->
        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3">
            <Border Background="White" CornerRadius="20" Opacity="0.3" Margin="10,20,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <TextBlock x:Name="DateTime_TextBlock" Text="localdate" Foreground="Gray" FontSize="20" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto" Margin="20,10,0,6"/>
            </Border>
        </StackPanel>

        <!-- Top right bar -->
        <Grid Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2">
            <Border Background="White" CornerRadius="20" Opacity="0.3" Margin="10,20,20,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Grid>

        <!-- Home Page -->
        <Grid Grid.Row="1" Grid.Column="1" Visibility="Hidden" x:Name="HomeGrid">
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="10,10,0,0">

                <TextBlock Text="Welcome back,"
               FontSize="24"
               FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto"
               Foreground="Gray"
               Margin="10,0,10,0"/>

                <TextBlock x:Name="UserNameTextBox" Text="{Binding UserName}" FontSize="24" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto" Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- USERS PAGE -->
        <Grid x:Name="UsersGrid" Grid.Row="1" Grid.Column="1" Grid.RowSpan="4" Grid.ColumnSpan="5" Margin="20" Visibility="Visible">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <DockPanel Grid.Row="0" Margin="0,0,0,10">

                <TextBlock Text="Users" FontSize="24" Foreground="White" VerticalAlignment="Center" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto"/>

                <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right">

                    <!-- SEARCH -->
                    <Border Background="#1F2937" CornerRadius="8" Padding="8" Margin="0,0,10,0">
                        <TextBox Width="180" Background="Transparent" BorderThickness="0" Foreground="White" Text="Search..." FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto"/>
                    </Border>

                    <!-- FILTER -->
                    <Button Content="Filter" Margin="0,0,10,0" Padding="12,6" Background="#374151" Foreground="White"  BorderThickness="0" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto"/>
                    <!-- ADD USER -->
                    <Button Content="Add User" Padding="14,6" Background="#10B981" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </DockPanel>


            <!-- USERS CARD -->
            <Border Grid.Row="2"
            Background="#111827"
            CornerRadius="12"
            Padding="20">

                <StackPanel>

                    <TextBlock Text="All Users"
                       Foreground="White"
                       FontSize="16"
                       Margin="0,0,0,10" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto"/>

                    <!-- USERS TABLE -->
                    <DataGrid AutoGenerateColumns="False" Background="Transparent" BorderThickness="0" GridLinesVisibility="None" RowBackground="#1F2937"
                      AlternatingRowBackground="#111827"
                      Foreground="White"
                      HeadersVisibility="Column"
                              ItemsSource="{Binding Users}" x:Name="UsersList">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto"/>
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto"/>
                            <DataGridTextColumn Header="When created" Binding="{Binding CreatedAt}" Width="170" FontFamily="/Resources/Roboto/Roboto-Regular.ttf#Roboto"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </Border>

        </Grid>
    </Grid>
</Window>
